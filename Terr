
🏗️ 1. Création de l’arborescence
Bash
mkdir -p openstack-gitlab/modules/{image,network,security,compute}

cd openstack-gitlab

touch main.tf provider.tf variables.tf outputs.tf cloud-init.yaml.tpl

touch modules/image/main.tf
touch modules/network/main.tf
touch modules/security/main.tf
touch modules/compute/main.tf
touch modules/compute/variables.tf
📄 2. provider.tf
Hcl
provider "openstack" {}
📄 3. variables.tf
Hcl
variable "external_network" {
  default = "public"
}

variable "gitlab_version" {
  default = "gitlab-ce-18.8.2-ce.0.el9"
}
📄 4. main.tf
Hcl
module "image" {
  source = "./modules/image"
}

module "network" {
  source           = "./modules/network"
  external_network = var.external_network
}

module "security" {
  source = "./modules/security"
}

module "compute" {
  source           = "./modules/compute"
  network_id       = module.network.network_id
  security_group   = module.security.secgroup_name
  image_name       = module.image.image_name
  gitlab_version   = var.gitlab_version
  external_network = var.external_network
}
📄 5. outputs.tf
Hcl
output "gitlab_url" {
  value = module.compute.public_ip
}
📄 6. cloud-init.yaml.tpl
YAML
#cloud-config

package_update: true
package_upgrade: true

runcmd:
  - yum install -y curl policycoreutils openssh-server perl
  - systemctl enable sshd
  - systemctl start sshd

  - curl https://packages.gitlab.com/install/repositories/gitlab/gitlab-ce/script.rpm.sh | bash

  - EXTERNAL_URL="http://$(curl -s ifconfig.me)" yum install -y ${gitlab_version}
📦 7. MODULE IMAGE
Hcl
resource "openstack_images_image_v2" "rocky" {
  name             = "Rocky-9"
  image_source_url = "https://download.rockylinux.org/pub/rocky/9/images/x86_64/Rocky-9-GenericCloud.latest.x86_64.qcow2"
  container_format = "bare"
  disk_format      = "qcow2"
}

output "image_name" {
  value = openstack_images_image_v2.rocky.name
}
🌐 8. MODULE NETWORK
Hcl
variable "external_network" {}

resource "openstack_networking_network_v2" "network" {
  name = "gitlab-network"
}

resource "openstack_networking_subnet_v2" "subnet" {
  name       = "gitlab-subnet"
  network_id = openstack_networking_network_v2.network.id
  cidr       = "192.168.100.0/24"
  ip_version = 4
  dns_nameservers = ["8.8.8.8"]
}

data "openstack_networking_network_v2" "external" {
  name = var.external_network
}

resource "openstack_networking_router_v2" "router" {
  name                = "gitlab-router"
  external_network_id = data.openstack_networking_network_v2.external.id
}

resource "openstack_networking_router_interface_v2" "interface" {
  router_id = openstack_networking_router_v2.router.id
  subnet_id = openstack_networking_subnet_v2.subnet.id
}

output "network_id" {
  value = openstack_networking_network_v2.network.id
}
🔐 9. MODULE SECURITY
Hcl
resource "openstack_networking_secgroup_v2" "sg" {
  name = "gitlab-secgroup"
}

resource "openstack_networking_secgroup_rule_v2" "ssh" {
  direction = "ingress"
  ethertype = "IPv4"
  protocol  = "tcp"
  port_range_min = 22
  port_range_max = 22
  remote_ip_prefix = "0.0.0.0/0"
  security_group_id = openstack_networking_secgroup_v2.sg.id
}

resource "openstack_networking_secgroup_rule_v2" "http" {
  direction = "ingress"
  ethertype = "IPv4"
  protocol  = "tcp"
  port_range_min = 80
  port_range_max = 80
  remote_ip_prefix = "0.0.0.0/0"
  security_group_id = openstack_networking_secgroup_v2.sg.id
}

resource "openstack_networking_secgroup_rule_v2" "https" {
  direction = "ingress"
  ethertype = "IPv4"
  protocol  = "tcp"
  port_range_min = 443
  port_range_max = 443
  remote_ip_prefix = "0.0.0.0/0"
  security_group_id = openstack_networking_secgroup_v2.sg.id
}

output "secgroup_name" {
  value = openstack_networking_secgroup_v2.sg.name
}
💻 10. MODULE COMPUTE
variables.tf
Hcl
variable "network_id" {}
variable "security_group" {}
variable "image_name" {}
variable "gitlab_version" {}
variable "external_network" {}
main.tf
Hcl
resource "openstack_compute_keypair_v2" "key" {
  name       = "gitlab-key"
  public_key = file("~/.ssh/id_rsa.pub")
}

resource "openstack_compute_instance_v2" "vm" {
  name        = "gitlab-server"
  flavor_name = "m1.medium"
  image_name  = var.image_name
  key_pair    = openstack_compute_keypair_v2.key.name

  security_groups = [var.security_group]

  network {
    uuid = var.network_id
  }

  user_data = templatefile("${path.module}/../../cloud-init.yaml.tpl", {
    gitlab_version = var.gitlab_version
  })
}

resource "openstack_networking_floatingip_v2" "fip" {
  pool = var.external_network
}

resource "openstack_compute_floatingip_associate_v2" "assoc" {
  floating_ip = openstack_networking_floatingip_v2.fip.address
  instance_id = openstack_compute_instance_v2.vm.id
}

output "public_ip" {
  value = openstack_networking_floatingip_v2.fip.address
}


terraform {
  required_providers {
    openstack = {
      source  = "terraform-provider-openstack/openstack"
      version = "~> 1.54.0"
    }
  }
}

provider "openstack" {}



