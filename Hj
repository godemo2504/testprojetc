YAML
#cloud-config

write_files:
  - path: /etc/resolv.conf
    content: |
      nameserver 185.12.64.2
      nameserver 185.12.64.1

runcmd:
  - set -ex
  - sleep 20

  # Fix réseau
  - ping -c 4 google.com

  # Packages de base
  - dnf update -y
  - dnf install -y curl policycoreutils openssh-server perl

  # SSH
  - systemctl enable sshd
  - systemctl start sshd

  # GitLab
  - curl -fsSL https://packages.gitlab.com/install/repositories/gitlab/gitlab-ce/script.rpm.sh -o /tmp/gitlab.sh
  - bash /tmp/gitlab.sh

  - EXTERNAL_URL="http://$(curl -s ifconfig.me)" dnf install -y gitlab-ce

  - gitlab-ctl reconfigure
🔍 2. SONARQUBE
YAML
#cloud-config

write_files:
  - path: /etc/resolv.conf
    content: |
      nameserver 185.12.64.2
      nameserver 185.12.64.1

runcmd:
  - set -ex
  - sleep 20

  - dnf update -y
  - dnf install -y java-17-openjdk wget unzip

  # SonarQube user
  - useradd sonar || true

  # Download SonarQube
  - cd /opt
  - wget https://binaries.sonarsource.com/Distribution/sonarqube/sonarqube-10.6.0.92116.zip
  - unzip sonarqube-*.zip
  - mv sonarqube-* sonarqube
  - chown -R sonar:sonar /opt/sonarqube

  # Start SonarQube
  - su - sonar -c "/opt/sonarqube/bin/linux-x86-64/sonar.sh start"
👉 Accès : http://IP:9000
⚙️ 3. JENKINS + ANSIBLE
YAML
#cloud-config

write_files:
  - path: /etc/resolv.conf
    content: |
      nameserver 185.12.64.2
      nameserver 185.12.64.1

runcmd:
  - set -ex
  - sleep 20

  - dnf update -y
  - dnf install -y java-17-openjdk wget git

  # Jenkins repo
  - wget -O /etc/yum.repos.d/jenkins.repo https://pkg.jenkins.io/redhat-stable/jenkins.repo
  - rpm --import https://pkg.jenkins.io/redhat-stable/jenkins.io-2023.key

  - dnf install -y jenkins

  # Start Jenkins
  - systemctl enable jenkins
  - systemctl start jenkins

  # Install Ansible
  - dnf install -y epel-release
  - dnf install -y ansible

  # Info
  - cat /var/lib/jenkins/secrets/initialAdminPassword > /root/jenkins_pwd.txt
👉 Accès : http://IP:8080
