🚀 3. MAIN.TF (MULTI VM)
👉 Maintenant tu déclares tes VM comme des services 👇
GitLab
Hcl
module "gitlab" {
  source = "./modules/vm"

  name             = "gitlab-server"
  flavor           = "m1.medium"
  image            = module.image.image_name
  network_id       = module.network.network_id
  security_group   = module.security.secgroup_name
  external_network = var.external_network
  keypair          = "gitlab-key"

  cloud_init = "${path.module}/cloud-init/gitlab.yaml.tpl"
}
